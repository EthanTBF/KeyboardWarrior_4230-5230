    ["J", 159, 44, 9, 11],
    ["K", 173, 44, 9, 11],
    ["L", 187, 44, 9, 11],
    ["ENTER", 203, 44, 34, 11],

    // bottom letter row
    ["LSHIFT", 40, 60, 35, 11],
