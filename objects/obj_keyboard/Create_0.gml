    ["I", 172, 28, 9, 11],
    ["O", 186, 28, 9, 11],
    ["P", 200, 28, 9, 11],
    ["BACKSPACE", 215, 28, 34, 11],

    // home row
    ["CAPS", 38, 44, 33, 11],
    ["A", 75, 44, 9, 11],
    ["S", 89, 44, 9, 11],
    ["D", 103, 44, 9, 11],
    ["F", 117, 44, 9, 11],
