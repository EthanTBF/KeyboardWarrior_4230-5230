max_hp = 100;
hp = max_hp;
global.explosive_letters = [];

press_time_default = 4;
key_timers = ds_map_create();

// each entry: [label, x, y, w, h]
// x/y are local
keys = [
    ["ESC", 30, 10, 28, 12],

    // number row
    ["1", 64 , 10, 10, 11],
    ["2", 78, 10, 10, 11],
    ["3", 92, 10, 10, 11],
    ["4", 106, 10, 10, 11],
    ["5", 120, 10, 10, 11],
    ["6", 134, 10, 10, 11],
    ["7", 148, 10, 10, 11],
    ["8", 162, 10, 10, 11],
    ["9", 176, 10, 10, 11],
    ["0", 190, 10, 10, 11],

    // Q row
    ["TAB", 39, 28, 26, 11],
    ["Q", 74, 28, 9, 11],
    ["W", 88, 28, 9, 11],
    ["E", 102, 28, 9, 11],
    ["R", 116, 28, 9, 11],
